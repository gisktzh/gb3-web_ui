anisation\":\"ARE Raumplanung\",\"geolion_gdd\":3618,\"geolion_karten_uuid\":\"30e216c8-e02d-4c1d-bf1c-15c0aad52d39\",\"keywords\":[\"Kernzonenpläne\"],\"notice\":\"Bitte beachten Sie, dass die Inhalte und die Darstellung in der vorliegenden GIS-Browserkarte «Kernzonenpläne» von den genehmigten Kernzonenplänen der Gemeinden abweichen können. Rechtsverbindlich und massgebend sind daher ausschliesslich die rechtskräftigen Kernzonenpläne. Zu beachten ist im Weiteren, dass vorliegend nur rechtskräftige Planinhalte wiedergegeben werden und keine weiteren Verfahrensstände.\",\"timesliderConfiguration\":null,\"filterConfigurations\":null,\"searchConfigurations\":null,\"wms_url\":\"https://maps.zh.ch/wms/AreRpKernzonenplaeneZH\",\"gb2_url\":null,\"opacity\":0.8,\"layers\":[{\"id\":221738,\"geolion_gds\":155,\"geolion_geodatensatz_uuid\":\"47e626f6-1359-4fc7-9953-d6bc74ec58c5\",\"layer\":\"kernzoneneplan_np_ul_f\",\"group_title\":\"Kernzonenplan\",\"title\":\"Kernzonenplan: Flächen (ÖREB)\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":0,\"toc_sort\":0,\"initially_visible\":true,\"queryable\":true},{\"id\":221739,\"geolion_gds\":155,\"geolion_geodatensatz_uuid\":\"47e626f6-1359-4fc7-9953-d6bc74ec58c5\",\"layer\":\"kernzoneneplan_np_ul_l\",\"group_title\":\"Kernzonenplan\",\"title\":\"Kernzonenplan: Linien (ÖREB)\",\"min_scale\":1,\"max_scale\":30000,\"wms_sort\":1,\"toc_sort\":100,\"initially_visible\":true,\"queryable\":true},{\"id\":221740,\"geolion_gds\":155,\"geolion_geodatensatz_uuid\":\"47e626f6-1359-4fc7-9953-d6bc74ec58c5\",\"layer\":\"kernzoneneplan_np_ul_p\",\"group_title\":\"Kernzonenplan\",\"title\":\"Kernzonenplan: Punkte (ÖREB)\",\"min_scale\":1,\"max_scale\":30000,\"wms_sort\":2,\"toc_sort\":200,\"initially_visible\":true,\"queryable\":true}],\"min_scale\":null},{\"topic\":\"StatQuartiereZH\",\"title\":\"Quartieranalyse\",\"print_title\":\"Quartieranalyse\",\"icon\":\"/images/custom/themekl-statquartierezh.gif\",\"organisation\":\"Statistisches Amt\",\"geo