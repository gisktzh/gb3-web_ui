,\"queryable\":true},{\"id\":230657,\"geolion_gds\":488,\"geolion_geodatensatz_uuid\":\"5eff9fbd-47e0-4f84-be28-536b974d7835\",\"layer\":\"gyger\",\"group_title\":null,\"title\":\"Historische Karte Hans Conrad Gyger (1667)\",\"min_scale\":400,\"max_scale\":1500000,\"wms_sort\":10,\"toc_sort\":1000,\"initially_visible\":true,\"queryable\":false},{\"id\":230658,\"geolion_gds\":488,\"geolion_geodatensatz_uuid\":\"5eff9fbd-47e0-4f84-be28-536b974d7835\",\"layer\":\"gyger56abfrage\",\"group_title\":null,\"title\":\"Gyger: Abfrage 56 Einzelblätter\",\"min_scale\":250,\"max_scale\":1500000,\"wms_sort\":11,\"toc_sort\":1100,\"initially_visible\":true,\"queryable\":true},{\"id\":230659,\"geolion_gds\":488,\"geolion_geodatensatz_uuid\":\"5eff9fbd-47e0-4f84-be28-536b974d7835\",\"layer\":\"gyger56blaetter\",\"group_title\":null,\"title\":\"Gyger: 56 Einzelblätter\",\"min_scale\":250,\"max_scale\":1500000,\"wms_sort\":12,\"toc_sort\":1200,\"initially_visible\":false,\"queryable\":true},{\"id\":230660,\"geolion_gds\":488,\"geolion_geodatensatz_uuid\":\"5eff9fbd-47e0-4f84-be28-536b974d7835\",\"layer\":\"blattnummern\",\"group_title\":null,\"title\":\"Blattnummern\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":13,\"toc_sort\":1300,\"initially_visible\":false,\"queryable\":false}],\"min_scale\":null},{\"topic\":\"HistGewKarteZH\",\"title\":\"Historische Gewässerkarte des Kantons Zürich\",\"print_title\":\"Historische Gewässerkarte des Kantons Zürich\",\"icon\":\"/images/custom/themekl-histgewkartezh.gif\",\"organisation\":\"AWEL Gewässerschutz GS\",\"geolion_gdd\":null,\"geolion_karten_uuid\":\"570ec2c3-477d-4388-8b3d-a548c156588e\",\"keywords\":[\"Historische\",\"Gewässerkarte\",\"des\",\"Kantons\",\"Zürich\",\"awel\",\"hist\",\"123\",\"fap\",\"wasser\",\"Historische_Gewässerkarte_1980\",\"1980\"],\"notice\":\"«Veränderung der Gewässer und Feuchtgebiete im Kanton Zürich 1850, 1890 und 1980.» Die Diplomarbeit des Geografen Roland Brändli vom Geografischen Institut der Uni Zürich - Irchel vom August 1990 zeigt die Veränderungen der Gewässer und Feuchtgebiete im Kanton Zürich zwischen 1850, 1890 und 1980 auf. Während diesen 2 Epochen geht es um die drei Kategorien \\\"Seither verschwundene, unverändert und neu dazugekommene Gewässer und Feuchtgebiete\\\", was in den Swisstopo-Karten 1:25'000 festgehalten wurde. Diese analogen Kartenblätter wurden georeferenziert eingescannt und können als Hintergrundrasterkarte genutzt werden.\",\"timesliderConfiguration\":null,\"filterConfigurations\":null,\"searchConfigurations\":[{\"index\":\"gewaesserangaben\",\"title\":\"Gewässer\"}],\"wms_url\":\"https://maps.zh.ch/wms/HistGewKarteZH\",\"gb2_url\":null,\"opacity\":1,\"layers\":[{\"id\":192023,\"geolion_gds\":347,\"geolion_geodatensatz_uuid\":\"5192f2c6-a4be-984f-5051-0ae59a9227aa\",\"layer\":\"HistGewKarte\",\"group_title\":null,\"title\":\"Historische Gewässerkarte\",\"min_scale\":1,\"max_scale\":50000,\"wms_sort\":6,\"toc_sort\":600,\"initially_visible\":true,\"queryable\":false}],\"min_scale\":null},{\"topic\":\"StaOldmapsZH\",\"title\":\"Historische Karten aus Staatsarchiv und Zentralbibliothek\",\"print_title\":\"Historische Karten aus Staatsarchiv und Zentralbibliothek\",\"icon\":\"/images/custom/themekl-staoldmapszh.gif\",\"organisation\":\"Staatsarchiv\",\"geolion_gdd\":null,\"geolion_karten_uuid\":\"0790f7dc-1d95-4a77-a71e-5d3dd81dd096\",\"keywords\":[\"Historische\",\"Karten\",\"aus\",\"Staatsarchiv\",\"und\",\"Zentralbibliothek\",\"fap\"],\"notice\":\"Die Layer 'Staatsarchiv des Kantons Zürich' und 'Zentralbibliothek Zürich' enthalten alle historischen Karten dieser beiden Institutionen. Der Time Slider filtert nur diese beiden Karten und nur visuell; die Infoabfrage zeigt alle Einträge, auch wenn die Zeitspanne durch den Time Slider eingeschränkt ist. Die unteren Ebenen filtern die historischen Karten nach Jahr oder nach Massstab und werden nur korrekt dargestellt, wenn die zwei obersten Ebenen deaktiviert sind. Bei den Ebenen nach Jahr oder nach Massstab wird die Infoabfrage entsprechend gefiltert.\",\"timesliderConfiguration\":{\"name\":\"Karten von 1547 bis 2016\",\"source\":{\"layerIdentifiers\":[\"stazh\",\"zbz\"],\"endRangeParameter\":\"YEAR_TO\",\"startRangeParameter\":\"YEAR_FROM\"},\"dateFormat\":\"YYYY\",\"sourceType\":\"parameter\",\"maximumDate\":\"2016\",\"minimumDate\":\"1547\",\"minimalRange\":\"P1Y\",\"alwaysMaxRange\":false},\"filterConfigurations\":null,\"searchConfigurations\":null,\"wms_url\":\"https://maps.zh.ch/wms/StaOldmapsZH\",\"gb2_url\":null,\"opacity\":1,\"layers\":[{\"id\":236496,\"geolion_gds\":422,\"geolion_geodatensatz_uuid\":\"0a292a4b-719b-4f28-aafa-2fbdd761c468\",\"layer\":\"ms-210000\",\"group_title\":null,\"title\":\"Massstäbe über 1:210'000\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":0,\"toc_sort\":0,\"initially_visible\":false,\"queryable\":true},{\"id\":236497,\"geolion_gds\":422,\"geolion_geodatensatz_uuid\":\"0a292a4b-719b-4f28-aafa-2fbdd761c468\",\"layer\":\"ms-30001-210000\",\"group_title\":null,\"title\":\"Massstäbe von 1:30'001 bis 1:210'000\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":1,\"toc_sort\":100,\"initially_visible\":false,\"queryable\":true},{\"id\":236498,\"geolion_gds\":422,\"geolion_geodatensatz_uuid\":\"0a292a4b-719b-4f28-aafa-2fbdd761c468\",\"layer\":\"ms-20001-30000\",\"group_title\":null,\"title\":\"Massstäbe von 1:20'001 bis 1:30'000\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":2,\"toc_sort\":200,\"initially_visible\":false,\"queryable\":true},{\"id\":236499,\"geolion_gds\":422,\"geolion_geodatensatz_uuid\":\"0a292a4b-719b-4f28-aafa-2fbdd761c468\",\"layer\":\"ms-2601-20000\",\"group_title\":null,\"title\":\"Massstäbe von 1:2'601 bis 1:20'000\",\"min_scale\":1,\"max_scale\":1500000,\"wms_sort\":3,\"toc_sort\":300,\"initially_visible\":false,\"queryable\":true},{\"id\":236500,\"geolion_gds\":422,\"geolion_geodatensatz_uuid\":\"0a292a4b-719b-4f28-aafa-2fbdd761c468\",\"layer\":\"ms-1000-2600\",\"group_title\":null,\"