{
  "name": "gb3-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-local-gb2": "ng serve --configuration=development-local-gb2 --host 0.0.0.0 --port 4242 --poll 1000",
    "build-local": "ng build --configuration=development",
    "build-local-gb2": "ng build --configuration=development-local-gb2",
    "build-dev-ebp": "node ./update-version.js && ng build --configuration=production-dev-ebp",
    "build-uat": "ng build --configuration=production-uat",
    "build-staging": "ng build --configuration=production-staging",
    "build-staging-using-productive-gb2-backend": "ng build --configuration=production-staging-using-productive-gb2-backend",
    "build-production": "ng build --configuration=production",
    "watch": "ng build --configuration development",
    "test": "ng test",
    "test-ci": "ng test --no-watch --no-progress --coverage",
    "prepare": "node ./prepare.mjs",
    "update-version": "node ./update-version.js",
    "format-all": "prettier --write ./src",
    "generate-gb3-api": "npx swagger-typescript-api generate -p https://maps.zh.ch/api-docs/gb3/v4/swagger.yaml -o ./src/app/shared/models -n gb3-api-generated.interfaces.ts --no-client --extract-response-body --extract-request-body --extract-request-body && node ./remove-generated-api-version-references.js ./src/app/shared/models/gb3-api-generated.interfaces.ts",
    "lint": "eslint",
    "knip": "knip",
    "e2e": "ng e2e"
  },
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/build": "^21.0.4",
    "@angular/cdk": "^21.0.5",
    "@angular/cli": "^21.0.4",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/compiler-cli": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/localize": "^21.0.6",
    "@angular/material": "^21.0.5",
    "@angular/platform-browser": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@arcgis/core": "5.1.6",
    "@gisktzh/cim-symbol-to-svg": "^1.0.1",
    "@ngrx/effects": "^21.0.0",
    "@ngrx/entity": "^21.0.0",
    "@ngrx/operators": "^21.0.0",
    "@ngrx/router-store": "^21.0.0",
    "@ngrx/store": "^21.0.0",
    "@ngrx/store-devtools": "^21.0.0",
    "@terraformer/arcgis": "^2.1.2",
    "@types/file-saver": "^2.0.7",
    "@types/geojson": "^7946.0.10",
    "@types/terraformer__arcgis": "^2.0.2",
    "angular-oauth2-oidc": "^20.0.0",
    "angular-resizable-element": "^8.0.0",
    "chart.js": "^4.5.0",
    "dayjs": "^1.11.7",
    "file-saver": "^2.0.5",
    "geojson": "^0.5.0",
    "immer": "^11.0.0",
    "material-icons": "^1.13.12",
    "ng-click-outside2": "^19.0.0",
    "ng2-charts": "^10.0.0",
    "ngx-ui-tour-md-menu": "^16.0.0",
    "playwright": "^1.61.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@eslint/js": "^9.19.0",
    "@ngrx/eslint-plugin": "^20.0.0",
    "@ngrx/schematics": "^21.0.0",
    "@playwright/test": "^1.61.1",
    "@types/har-format": "^1.2.16",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/spy": "^4.1.0",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-rxjs-angular-x": "^0.1.0",
    "eslint-plugin-rxjs-x": "~0.9.1",
    "husky": "^9.0.0",
    "jsdom": "^29.0.0",
    "knip": "~6.23.0",
    "lint-staged": "^17.0.0",
    "playwright-advanced-har": "^1.4.1",
    "playwright-ng-schematics": "^21.0.5",
    "prettier": "^3.3.3",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.18"
  }
}
